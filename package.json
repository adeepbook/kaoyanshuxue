{
  "name": "kaoyan-study-map",
  "version": "2.0.0",
  "description": "考研数学学习进度地图 —— 每科独立 · 数一/数三标注 · 前置追溯 · 多模型 AI · 复盘导出",
  "main": "main.js",
  "scripts": {
    "build": "node build.js",
    "start": "node build.js && electron .",
    "dist": "node build.js && electron-builder",
    "dist:win": "node build.js && electron-builder --win"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.anse.kaoyanstudymap",
    "productName": "KaoyanStudyMap",
    "files": ["index.html", "*.html", "main.js", "preload.js", "template.html", "build.js"],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}
